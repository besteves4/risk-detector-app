@prefix : <http://example.com/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix tosl: <https://w3id.org/tosl/> .
@base <http://example.com> .

:Agreement a odrl:Agreement ;
    dcterms:title "Agreement with a pricing modification term" ;
    :policyGraph {
        :permissionChangePricing a odrl:Permission ;
            dcterms:description "Provider may change prices from time to time.";
            odrl:assignee :provider ;
            odrl:action odrl:modify;
            odrl:target :pricing ;
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand odrl:delayPeriod ;
                odrl:operator odrl:gteq ;
                odrl:rightOperand "P30D"^^xsd:duration
            ] ;
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand dpv:hasJustification ; # or dpv:Justification
                odrl:operator odrl:isAnyOf ;
                odrl:rightOperand (
                    justifications:LegalObligation # ServiceUpdate and ImproveFeatures
                )
            ] ;
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand dpv:hasConsentStatus ; # or dpv:ConsentStatus
                odrl:operator odrl:eq ;
                odrl:rightOperand dpv:ConsentGiven
            ] ;
            odrl:duty [
                a odrl:Duty ;
                odrl:action dpv:ReaffirmConsent ;
                odrl:assignee :customer ;
                odrl:target :pricing
            ] .
            odrl:duty [
                a odrl:Duty ;
                odrl:action odrl:inform ;
                odrl:assignee :provider ;
                odrl:target :pricing ;
                odrl:informedParty :customer ;
                odrl:constraint [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:deliveryChannel ;
                    odrl:operator odrl:isAnyOf ;
                    odrl:rightOperand ( "email"^^xsd:string "inProductNotification"^^xsd:string )
                ] ;
            ] .   
        
        :provider a dpv:ServiceProvider .
        :customer a dpv:Customer .
    } .
