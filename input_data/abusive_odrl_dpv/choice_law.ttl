@prefix : <http://example.com/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix dpv-odrl: <https://w3id.org/dpv/odrl> .
@prefix dpv: <https://w3id.org/dpv> .
@prefix pd: <https://w3id.org/dpv/pd#> .
@prefix loc: <https://w3id.org/dpv/loc#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix justifications: <https://w3id.org/dpv/justifications> .
@prefix legal-nl: <https://w3id.org/dpv/legal/nl> .
@base <http://example.com> .


:Agreement a odrl:Agreement ;
    dcterms:title "Agreement with litigation process governed by netherlandsLaw" ;
    :policyGraph {
        :DutyChoiceOfLaw a odrl:Duty ;
            dcterms:description "Agreement with litigation process governed by netherlandsLaw" ;
            odrl:assignee :customer ;
            odrl:action dpv-odrl:GovernanceProcedures ;
            odrl:target :agreement ;
            odrl:constraint [
                a odrl:Constraint;
                odrl:leftOperand dpv:hasJurisdiction ;
                odrl:operator odrl:eq ;
                odrl:rightOperand legal-nl:law-GDPR
            ] ;
            odrl:constraint [
                a odrl:Constraint;
                odrl:leftOperand dpv:hasApplicableLaw ;
                odrl:operator odrl:eq ;
                odrl:rightOperand loc:NL
            ] .
            
        :customer a dpv:Customer .
    } .

